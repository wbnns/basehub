---
import StarlightPage from '@astrojs/starlight/components/StarlightPage.astro';
import { Icon } from '@astrojs/starlight/components';
---

<StarlightPage
  frontmatter={{
    title: 'BaseHub',
    description: 'The go-to resource for Base Chain technical information. Network reference, RPC APIs, Flashblocks, node operation, and the Rust client.',
    template: 'splash',
    hero: { tagline: '' },
    pagefind: false,
  }}
>
  <div class="home">
    <header class="home-hero">
      <span class="home-eyebrow">Base Chain documentation</span>
      <h1>Everything technical about Base, in one place.</h1>
      <p>
        Network reference, RPC APIs, Flashblocks, node operation,
        and the open-source Rust client behind <code>base/base</code>.
      </p>
    </header>

    <section class="home-cards" aria-label="Documentation sections">
      <a class="home-card" href="/introduction/why-base/">
        <span class="home-card-icon" aria-hidden="true"><Icon name="rocket" size="1.125rem" /></span>
        <h3>Introduction <span class="home-arrow" aria-hidden="true">→</span></h3>
        <p>Why Base, how to connect, and how to deploy your first contract.</p>
      </a>

      <a class="home-card" href="/network/base-contracts/">
        <span class="home-card-icon" aria-hidden="true"><Icon name="random" size="1.125rem" /></span>
        <h3>Network <span class="home-arrow" aria-hidden="true">→</span></h3>
        <p>Contracts, bridges, fees, faucets, finality, and chain differences.</p>
      </a>

      <a class="home-card" href="/api-reference/rpc-overview/">
        <span class="home-card-icon" aria-hidden="true"><Icon name="list-format" size="1.125rem" /></span>
        <h3>API reference <span class="home-arrow" aria-hidden="true">→</span></h3>
        <p>Every JSON-RPC method on Base, with parameters and examples.</p>
      </a>

      <a class="home-card" href="/flashblocks/overview/">
        <span class="home-card-icon" aria-hidden="true"><Icon name="document" size="1.125rem" /></span>
        <h3>Flashblocks <span class="home-arrow" aria-hidden="true">→</span></h3>
        <p>The 200ms preconfirmation protocol — overview, integration, and spec.</p>
      </a>

      <a class="home-card" href="/getting-started/prerequisites/">
        <span class="home-card-icon" aria-hidden="true"><Icon name="setting" size="1.125rem" /></span>
        <h3>Run a node <span class="home-arrow" aria-hidden="true">→</span></h3>
        <p>Build, deploy, and operate a Base node — Docker, config, monitoring.</p>
      </a>

      <a class="home-card" href="/architecture/overview/">
        <span class="home-card-icon" aria-hidden="true"><Icon name="puzzle" size="1.125rem" /></span>
        <h3>Architecture &amp; crates <span class="home-arrow" aria-hidden="true">→</span></h3>
        <p>System design and seventy-plus Rust crates inside <code>base/base</code>.</p>
      </a>
    </section>

    <section class="home-feature" aria-label="Build with Base">
      <a class="home-card home-card--feature" href="/introduction/connecting-to-base/">
        <div class="home-card-body">
          <span class="home-card-eyebrow">Connect</span>
          <h3>Talk to Base in one line <span class="home-arrow" aria-hidden="true">→</span></h3>
          <p>Mainnet and Sepolia public endpoints, ready for any RPC client.</p>
        </div>
        <pre class="home-card-snippet"><code>cast block-number --rpc-url https://mainnet.base.org</code></pre>
      </a>

      <a class="home-card home-card--feature" href="/flashblocks/app-integration/">
        <div class="home-card-body">
          <span class="home-card-eyebrow">Stream Flashblocks</span>
          <h3>Subscribe to 200ms preconfirmations <span class="home-arrow" aria-hidden="true">→</span></h3>
          <p>WebSocket stream of mini-blocks delivered five times per slot.</p>
        </div>
        <pre class="home-card-snippet"><code>wscat -c wss://mainnet.base.org/flashblocks</code></pre>
      </a>
    </section>

    <section class="home-popular">
      <h2>Popular references</h2>
      <ul>
        <li><a href="/network/base-contracts/">Base contracts <span aria-hidden="true">→</span></a></li>
        <li><a href="/network/network-fees/">Fee model <span aria-hidden="true">→</span></a></li>
        <li><a href="/network/diffs-ethereum-base/">Base vs. Ethereum <span aria-hidden="true">→</span></a></li>
        <li><a href="/api-reference/eth/eth_getlogs/">eth_getLogs <span aria-hidden="true">→</span></a></li>
        <li><a href="/flashblocks/overview/">Flashblocks overview <span aria-hidden="true">→</span></a></li>
        <li><a href="/security/bug-bounty/">Bug bounty <span aria-hidden="true">→</span></a></li>
      </ul>
    </section>
  </div>
</StarlightPage>
