---
import StarlightPage from '@astrojs/starlight/components/StarlightPage.astro';
---

<StarlightPage
  frontmatter={{
    title: 'BaseHub',
    description: 'Technical reference for the base/base codebase — the Rust-based L2 node powering Base.',
    template: 'splash',
    hero: { tagline: '' },
    pagefind: false,
  }}
>
  <div class="home">
    <header class="home-hero">
      <h1>BaseHub</h1>
      <p>
        Technical reference for the <code>base/base</code> Rust codebase —
        the L2 node powering Base.
      </p>
    </header>

    <section class="home-cards" aria-label="Documentation sections">
      <a class="home-card" href="/architecture/overview/">
        <h3>Architecture <span class="home-arrow" aria-hidden="true">→</span></h3>
        <p>System design, crate map, and data flow from L1 to execution.</p>
      </a>

      <a class="home-card" href="/getting-started/prerequisites/">
        <h3>Getting Started <span class="home-arrow" aria-hidden="true">→</span></h3>
        <p>Prerequisites, building from source, running, and local devnet.</p>
      </a>

      <a class="home-card" href="/crates/overview/">
        <h3>Crate Reference <span class="home-arrow" aria-hidden="true">→</span></h3>
        <p>70+ crates across 8 groups — consensus, execution, builder, proof.</p>
      </a>

      <a class="home-card" href="/specifications/flashblocks/">
        <h3>Specifications <span class="home-arrow" aria-hidden="true">→</span></h3>
        <p>Flashblocks 200ms preconfirmation protocol and access lists.</p>
      </a>

      <a class="home-card" href="/integration-guides/connecting/">
        <h3>Integration Guides <span class="home-arrow" aria-hidden="true">→</span></h3>
        <p>Connect to Base, stream Flashblocks, and interact with the txpool.</p>
      </a>

      <a class="home-card" href="/node-operations/deployment/">
        <h3>Node Operations <span class="home-arrow" aria-hidden="true">→</span></h3>
        <p>Deployment, Docker, configuration, monitoring, and releases.</p>
      </a>
    </section>

    <section class="home-popular">
      <h2>Popular</h2>
      <ul>
        <li><a href="/getting-started/building/">Build from source</a></li>
        <li><a href="/getting-started/docker/">Run with Docker</a></li>
        <li><a href="/specifications/flashblocks/">Flashblocks spec</a></li>
        <li><a href="/integration-guides/flashblocks-rpc/">Flashblocks RPC</a></li>
        <li><a href="/node-operations/configuration/">Node configuration</a></li>
        <li><a href="/architecture/execution-pipeline/">Execution pipeline</a></li>
      </ul>
    </section>
  </div>
</StarlightPage>
