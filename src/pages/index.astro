---
import StarlightPage from '@astrojs/starlight/components/StarlightPage.astro';
import { Icon } from '@astrojs/starlight/components';
---

<StarlightPage
  frontmatter={{
    title: 'BaseHub',
    description: 'The Rust client powering Base. Architecture, crates, and integration guides — straight from the source.',
    template: 'splash',
    hero: { tagline: '' },
    pagefind: false,
  }}
>
  <div class="home">
    <header class="home-hero">
      <span class="home-eyebrow">Documentation</span>
      <h1>The Rust client powering Base.</h1>
      <p>
        Architecture, crates, and integration guides for <code>base/base</code> —
        straight from the source.
      </p>
    </header>

    <section class="home-cards" aria-label="Documentation sections">
      <a class="home-card" href="/architecture/overview/">
        <span class="home-card-icon" aria-hidden="true"><Icon name="puzzle" size="1.125rem" /></span>
        <h3>Architecture <span class="home-arrow" aria-hidden="true">→</span></h3>
        <p>System design, crate map, and the path from L1 to execution.</p>
      </a>

      <a class="home-card" href="/getting-started/prerequisites/">
        <span class="home-card-icon" aria-hidden="true"><Icon name="rocket" size="1.125rem" /></span>
        <h3>Getting started <span class="home-arrow" aria-hidden="true">→</span></h3>
        <p>Prerequisites, build from source, run a node, spin up a devnet.</p>
      </a>

      <a class="home-card" href="/crates/overview/">
        <span class="home-card-icon" aria-hidden="true"><Icon name="list-format" size="1.125rem" /></span>
        <h3>Crate reference <span class="home-arrow" aria-hidden="true">→</span></h3>
        <p>Seventy-plus crates across consensus, execution, builder, and proof.</p>
      </a>

      <a class="home-card" href="/specifications/flashblocks/">
        <span class="home-card-icon" aria-hidden="true"><Icon name="document" size="1.125rem" /></span>
        <h3>Specifications <span class="home-arrow" aria-hidden="true">→</span></h3>
        <p>Flashblocks 200ms preconfirmation protocol and access lists.</p>
      </a>

      <a class="home-card" href="/integration-guides/connecting/">
        <span class="home-card-icon" aria-hidden="true"><Icon name="random" size="1.125rem" /></span>
        <h3>Integration guides <span class="home-arrow" aria-hidden="true">→</span></h3>
        <p>Connect to Base, stream Flashblocks, work with the txpool.</p>
      </a>

      <a class="home-card" href="/node-operations/deployment/">
        <span class="home-card-icon" aria-hidden="true"><Icon name="setting" size="1.125rem" /></span>
        <h3>Node operations <span class="home-arrow" aria-hidden="true">→</span></h3>
        <p>Deployment, Docker, configuration, monitoring, and releases.</p>
      </a>
    </section>

    <section class="home-feature" aria-label="Build with Base">
      <a class="home-card home-card--feature" href="/getting-started/building/">
        <div class="home-card-body">
          <span class="home-card-eyebrow">Run a node</span>
          <h3>Build base-reth-node from source <span class="home-arrow" aria-hidden="true">→</span></h3>
          <p>Compile the full execution client with a single Cargo command.</p>
        </div>
        <pre class="home-card-snippet"><code>cargo install --path bin/base-reth-node</code></pre>
      </a>

      <a class="home-card home-card--feature" href="/integration-guides/flashblocks-rpc/">
        <div class="home-card-body">
          <span class="home-card-eyebrow">Stream Flashblocks</span>
          <h3>Subscribe to 200ms preconfirmations <span class="home-arrow" aria-hidden="true">→</span></h3>
          <p>WebSocket stream of mini-blocks delivered five times per slot.</p>
        </div>
        <pre class="home-card-snippet"><code>wscat -c wss://mainnet.base.org/flashblocks</code></pre>
      </a>
    </section>

    <section class="home-popular">
      <h2>Get started fast</h2>
      <ul>
        <li><a href="/getting-started/building/">Build from source <span aria-hidden="true">→</span></a></li>
        <li><a href="/getting-started/docker/">Run with Docker <span aria-hidden="true">→</span></a></li>
        <li><a href="/specifications/flashblocks/">Flashblocks spec <span aria-hidden="true">→</span></a></li>
        <li><a href="/integration-guides/flashblocks-rpc/">Flashblocks RPC <span aria-hidden="true">→</span></a></li>
        <li><a href="/node-operations/configuration/">Node configuration <span aria-hidden="true">→</span></a></li>
        <li><a href="/architecture/execution-pipeline/">Execution pipeline <span aria-hidden="true">→</span></a></li>
      </ul>
    </section>
  </div>
</StarlightPage>
