---
import Default from '@astrojs/starlight/components/Footer.astro';

const { entry, hasSidebar } = Astro.locals.starlightRoute;
const isDoc = !!entry?.id && entry.id !== 'index';
const url = new URL(Astro.url.pathname, Astro.site);
const markdownUrl = isDoc ? `${Astro.site}${entry.id}.md` : null;

const askPrompt = isDoc
  ? `I'm reading the BaseHub documentation page "${entry.data.title}" at ${url.href}. The raw markdown is at ${markdownUrl}. Please use it as authoritative context and help me with the following: `
  : '';

const claudeUrl = isDoc
  ? `https://claude.ai/new?q=${encodeURIComponent(askPrompt)}`
  : null;
const chatgptUrl = isDoc
  ? `https://chat.openai.com/?q=${encodeURIComponent(askPrompt)}`
  : null;
---

{isDoc && markdownUrl && (
  <aside class="bh-agent-actions" aria-label="Use this page with an AI agent">
    <span class="bh-agent-actions__label">Use with an agent</span>
    <div class="bh-agent-actions__row">
      <a class="bh-agent-actions__btn" href={markdownUrl}>View as Markdown</a>
      <a class="bh-agent-actions__btn" href={claudeUrl} target="_blank" rel="noopener">Open in Claude</a>
      <a class="bh-agent-actions__btn" href={chatgptUrl} target="_blank" rel="noopener">Open in ChatGPT</a>
      <button
        class="bh-agent-actions__btn"
        type="button"
        data-bh-copy={markdownUrl}
        aria-label="Copy Markdown URL"
      >Copy MD URL</button>
    </div>
    <p class="bh-agent-actions__hint">
      Every BaseHub page exposes raw Markdown — append <code>.md</code> to the URL. See <a href="/llms.txt">/llms.txt</a> and <a href="/llms-full.txt">/llms-full.txt</a> for the full agent index.
    </p>
  </aside>
)}

<Default><slot /></Default>

<aside class="bh-disclaimer" role="contentinfo" aria-label="Project disclaimer">
  <p>
    <a href="https://github.com/wbnns/basehub" target="_blank" rel="noopener">BaseHub</a> is a compendium of open resources about Base, assembled into one site and built for agents. Not affiliated with or endorsed by Coinbase or any related entity. <a href="https://github.com/wbnns/basehub/blob/main/LICENSE" target="_blank" rel="noopener">MIT License</a>.
  </p>
</aside>

<script>
  document.addEventListener('click', (event) => {
    const target = event.target as HTMLElement | null;
    const btn = target?.closest<HTMLElement>('[data-bh-copy]');
    if (!btn) return;
    const value = btn.getAttribute('data-bh-copy');
    if (!value) return;
    navigator.clipboard?.writeText(value).then(() => {
      const original = btn.textContent;
      btn.textContent = 'Copied';
      setTimeout(() => {
        if (btn.textContent === 'Copied') btn.textContent = original;
      }, 1500);
    });
  });

  // Search dialog empty state — when the input is empty, fill the
  // otherwise-blank modal with curated quick links so it never reads as
  // a wall of whitespace.
  const EMPTY_STATE_HTML = `
    <div class="bh-search-empty__col">
      <h3>Popular pages</h3>
      <ul>
        <li><a href="/network/base-contracts/">Base contracts</a></li>
        <li><a href="/network/network-fees/">Fee model</a></li>
        <li><a href="/network/diffs-ethereum-base/">Base vs. Ethereum</a></li>
        <li><a href="/api-reference/eth/eth_getlogs/">eth_getLogs</a></li>
        <li><a href="/flashblocks/overview/">Flashblocks overview</a></li>
        <li><a href="/security/bug-bounty/">Bug bounty</a></li>
      </ul>
    </div>
    <div class="bh-search-empty__col">
      <h3>For agents</h3>
      <ul>
        <li><a href="/llms.txt"><code>/llms.txt</code></a></li>
        <li><a href="/llms-full.txt"><code>/llms-full.txt</code></a></li>
        <li><a href="/api/pages.json"><code>/api/pages.json</code></a></li>
        <li><a href="https://www.npmjs.com/package/@wbnns/base-mcp">MCP server</a></li>
        <li><a href="/feeds/blog.xml"><code>/feeds/blog.xml</code></a></li>
        <li><a href="/feeds/status.xml"><code>/feeds/status.xml</code></a></li>
      </ul>
    </div>
  `;

  const wireDialog = (dialog: HTMLDialogElement) => {
    const frame = dialog.querySelector('.dialog-frame');
    if (!frame) return false;
    let panel = frame.querySelector<HTMLDivElement>('.bh-search-empty');
    if (!panel) {
      panel = document.createElement('div');
      panel.className = 'bh-search-empty';
      panel.innerHTML = EMPTY_STATE_HTML;
      frame.appendChild(panel);
    }
    const input = dialog.querySelector<HTMLInputElement>('.pagefind-ui__search-input');
    if (input && !input.dataset.bhWired) {
      input.dataset.bhWired = '1';
      const sync = () => {
        const isEmpty = input.value.trim() === '';
        dialog.toggleAttribute('data-bh-empty', isEmpty);
      };
      input.addEventListener('input', sync);
      input.addEventListener('focus', sync);
      sync();
    } else if (!input) {
      // Pagefind hasn't mounted yet — keep the empty state visible by default.
      dialog.setAttribute('data-bh-empty', '');
    }
    return !!input;
  };

  document.querySelectorAll<HTMLElement>('site-search').forEach((el) => {
    const dialog = el.querySelector<HTMLDialogElement>('dialog');
    if (!dialog) return;
    wireDialog(dialog);
    const observer = new MutationObserver(() => {
      if (wireDialog(dialog)) {
        // Once the input is wired we still want to keep observing for
        // cases where the dialog frame is replaced, so do not disconnect.
      }
    });
    observer.observe(dialog, { childList: true, subtree: true });
  });
</script>

<style>
  .bh-agent-actions {
    margin: 2.5rem 0 1.5rem;
    padding: 1rem 1.25rem;
    border: 1px solid var(--sl-color-hairline-light);
    border-radius: 10px;
    background: var(--sl-color-gray-7, #f5f6f8);
  }
  .bh-agent-actions__label {
    display: block;
    font-size: 0.6875rem;
    font-weight: 600;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--sl-color-gray-2);
    margin-bottom: 0.625rem;
  }
  .bh-agent-actions__row {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
  }
  .bh-agent-actions__btn {
    display: inline-flex;
    align-items: center;
    padding: 0.375rem 0.75rem;
    border: 1px solid var(--sl-color-hairline-light);
    border-radius: 6px;
    background: var(--sl-color-bg, #fff);
    color: var(--sl-color-text);
    font-size: 0.8125rem;
    font-weight: 500;
    line-height: 1.2;
    text-decoration: none;
    cursor: pointer;
    transition: border-color 120ms ease, color 120ms ease;
  }
  .bh-agent-actions__btn:hover {
    border-color: var(--sl-color-accent);
    color: var(--sl-color-accent);
  }
  .bh-agent-actions__hint {
    margin: 0.75rem 0 0;
    font-size: 0.8125rem;
    color: var(--sl-color-gray-2);
  }
  .bh-agent-actions__hint code {
    font-size: 0.8125em;
  }
  .bh-disclaimer {
    margin-top: 2rem;
    padding: 0.875rem 0;
    border-top: 1px solid var(--sl-color-hairline-light);
    font-size: 0.8125rem;
    color: var(--sl-color-gray-3);
    line-height: 1.5;
  }
  .bh-disclaimer p {
    margin: 0;
  }
  .bh-disclaimer strong {
    color: var(--sl-color-gray-2);
    font-weight: 600;
  }
  .bh-disclaimer a {
    color: inherit;
    text-decoration: underline;
    text-decoration-thickness: 1px;
    text-underline-offset: 2px;
  }
  .bh-disclaimer a:hover {
    color: var(--sl-color-accent);
  }
</style>
