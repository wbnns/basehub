---
/**
 * Stripe-style two-column layout: prose on the left, code pinned on the right.
 * Usage in MDX:
 *   import CodeColumns from '../../../components/CodeColumns.astro';
 *
 *   <CodeColumns>
 *     <div>Prose here…</div>
 *     ```bash
 *     git clone ...
 *     ```
 *   </CodeColumns>
 */
---

<div class="code-columns">
  <slot />
</div>

<style>
  .code-columns {
    display: grid;
    grid-template-columns: minmax(0, 1.05fr) minmax(0, 0.95fr);
    gap: 2.5rem;
    margin: 2rem 0;
    align-items: start;
    scroll-margin-top: 6rem;
  }

  .code-columns > :nth-child(2) {
    position: sticky;
    top: calc(var(--sl-nav-height, 3.5rem) + 1.5rem);
    align-self: start;
  }

  .code-columns > :nth-child(2) :global(.expressive-code) {
    margin: 0 !important;
  }

  @media (max-width: 60rem) {
    .code-columns {
      grid-template-columns: 1fr;
      gap: 1rem;
    }
    .code-columns > :nth-child(2) {
      position: static;
    }
  }
</style>
